<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KLYN — Qüestionari de mercat</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #232d56;
    --navy-mid: #2e3b6e;
    --navy-light: #e8eaf2;
    --navy-xlight: #f2f3f8;
    --silver: #c8cdd5;
    --silver-light: #f0f1f3;
    --silver-dark: #8a9099;
    --white: #ffffff;
    --black: #000000;
    --text: #1a1a2e;
    --text-mid: #4a4f6b;
    --text-light: #8a9099;
    --border: #dde0e8;
    --radius: 10px;
    --radius-sm: 6px;
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: 'Montserrat', sans-serif;
    background: #f5f6fa;
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── HERO ── */
  .hero {
    background: var(--navy);
    color: var(--white);
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .hero-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #232d56 60%, #3a4a80 100%);
  }
  .hero-circle-1 {
    position: absolute; top: -80px; right: -80px;
    width: 320px; height: 320px; border-radius: 50%;
    background: rgba(200,205,213,0.07);
  }
  .hero-circle-2 {
    position: absolute; bottom: -60px; left: -40px;
    width: 200px; height: 200px; border-radius: 50%;
    background: rgba(200,205,213,0.05);
  }
  .hero-inner {
    max-width: 660px; margin: 0 auto;
    padding: 3rem 2rem 3.5rem;
    position: relative; z-index: 1;
  }

  /* Shoe logo SVG */
  .logo-wrap { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.4rem; }
  .logo-shoe {
    width: 80px; height: 40px; flex-shrink: 0;
  }
  .logo-text {
    font-size: 2.4rem; font-weight: 900; letter-spacing: 1px;
    color: var(--white);
  }
  .hero-sub {
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--silver);
    margin-bottom: 2rem;
    padding-left: 2px;
  }
  .hero-intro {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(200,205,213,0.25);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    font-size: 0.84rem; font-weight: 400;
    line-height: 1.75; color: rgba(255,255,255,0.85);
  }
  .esomar-tag {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 1rem;
    background: rgba(200,205,213,0.15);
    border: 1px solid rgba(200,205,213,0.3);
    border-radius: 99px; padding: 4px 14px;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--silver);
  }

  /* ── PROGRESS ── */
  .progress-wrap {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 2rem;
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 16px rgba(35,45,86,0.08);
  }
  .progress-meta {
    display: flex; justify-content: space-between; align-items: center;
    max-width: 660px; margin: 0 auto 0.55rem;
  }
  .progress-label { font-size: 0.75rem; font-weight: 700; color: var(--navy); letter-spacing: 0.04em; text-transform: uppercase; }
  .progress-count { font-size: 0.75rem; font-weight: 600; color: var(--text-light); font-variant-numeric: tabular-nums; }
  .progress-track { max-width: 660px; margin: 0 auto; height: 3px; background: var(--silver-light); border-radius: 99px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--navy); border-radius: 99px; transition: width 0.5s cubic-bezier(.4,0,.2,1); width: 0%; }

  /* ── MAIN ── */
  .main { max-width: 660px; margin: 0 auto; padding: 2rem 1.5rem 6rem; }

  /* ── SECTIONS ── */
  .section { display: none; animation: fadeUp 0.35s ease; }
  .section.active { display: block; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .section-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.68rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 5px 14px; border-radius: 99px;
    margin-bottom: 1.75rem;
  }
  .badge-filter   { background: var(--navy-light); color: var(--navy); }
  .badge-general  { background: #e8eef8; color: #1a3a6e; }
  .badge-specific { background: #eeeaf8; color: #3a1a6e; }
  .badge-purchase { background: #f8f0e8; color: #6e3a1a; }
  .badge-demo     { background: var(--silver-light); color: #4a4f6b; }

  /* ── QUESTION BLOCK ── */
  .q-block { margin-bottom: 2.25rem; }
  .q-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 0.45rem; }
  .q-num {
    font-size: 0.65rem; font-weight: 800; color: var(--silver-dark);
    letter-spacing: 0.1em; text-transform: uppercase;
    background: var(--silver-light); padding: 3px 8px; border-radius: 4px;
  }
  .q-type { font-size: 0.7rem; font-weight: 600; color: var(--navy-mid); }
  .q-text { font-size: 0.97rem; font-weight: 700; line-height: 1.5; color: var(--text); margin-bottom: 0.45rem; }
  .q-note { font-size: 0.75rem; color: var(--text-light); margin-bottom: 0.85rem; font-weight: 500; }

  /* ── OPTIONS ── */
  .options { display: flex; flex-direction: column; gap: 7px; }
  .opt-label {
    display: flex; align-items: center; gap: 12px;
    padding: 11px 15px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer; font-size: 0.87rem; font-weight: 500;
    color: var(--text-mid); transition: all 0.16s ease;
    background: var(--white); user-select: none;
  }
  .opt-label:hover {
    border-color: var(--navy);
    background: var(--navy-xlight);
    color: var(--navy);
  }
  .opt-label input { display: none; }
  .opt-label.selected {
    border-color: var(--navy);
    background: var(--navy-light);
    color: var(--navy);
    font-weight: 700;
  }
  .opt-dot {
    width: 18px; height: 18px;
    border: 2px solid var(--silver);
    border-radius: 50%; flex-shrink: 0;
    transition: all 0.16s;
    display: flex; align-items: center; justify-content: center;
  }
  .opt-label.selected .opt-dot {
    border-color: var(--navy); background: var(--navy);
  }
  .opt-dot::after {
    content: ''; width: 6px; height: 6px;
    border-radius: 50%; background: white;
    opacity: 0; transition: opacity 0.14s;
  }
  .opt-label.selected .opt-dot::after { opacity: 1; }

  /* checkbox variant */
  .opt-label.opt-box .opt-dot { border-radius: 3px; }
  .opt-label.opt-box.selected .opt-dot::after {
    content: '✓'; font-size: 10px; font-weight: 900;
    width: auto; height: auto; border-radius: 0;
    background: transparent; color: white; opacity: 1;
  }

  /* ── LIKERT ── */
  .likert-wrap { display: flex; flex-direction: column; gap: 10px; }
  .likert-scale { display: flex; gap: 8px; }
  .likert-btn {
    flex: 1; aspect-ratio: 1; max-width: 60px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--white); cursor: pointer;
    font-size: 0.9rem; font-weight: 700;
    color: var(--text-light);
    transition: all 0.16s;
    font-family: 'Montserrat', sans-serif;
  }
  .likert-btn:hover { border-color: var(--navy); color: var(--navy); background: var(--navy-xlight); }
  .likert-btn.selected { border-color: var(--navy); background: var(--navy); color: white; }
  .likert-labels { display: flex; justify-content: space-between; font-size: 0.7rem; font-weight: 600; color: var(--text-light); }

  /* ── RANK ── */
  .rank-list { display: flex; flex-direction: column; gap: 6px; }
  .rank-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--white); font-size: 0.87rem; font-weight: 500;
    color: var(--text-mid); transition: border-color 0.16s;
  }
  .rank-item:hover { border-color: var(--navy); }
  .rank-num {
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--navy); color: white;
    font-size: 0.72rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .rank-arrows { margin-left: auto; display: flex; flex-direction: column; gap: 1px; }
  .rank-arrows button {
    background: none; border: none; cursor: pointer;
    color: var(--silver-dark); font-size: 0.7rem; line-height: 1;
    padding: 2px 5px; border-radius: 3px; transition: all 0.14s;
  }
  .rank-arrows button:hover { color: var(--navy); background: var(--navy-light); }

  /* ── TEXTAREA ── */
  .q-textarea {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.87rem; font-weight: 500;
    color: var(--text); background: var(--white);
    resize: vertical; min-height: 96px;
    outline: none; transition: border-color 0.16s;
  }
  .q-textarea:focus { border-color: var(--navy); }
  .q-textarea::placeholder { color: var(--text-light); font-weight: 400; }

  /* ── NAV ── */
  .nav {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 2.5rem; padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 26px; border-radius: var(--radius-sm);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.82rem; font-weight: 700;
    cursor: pointer; letter-spacing: 0.03em;
    border: 1.5px solid var(--border);
    background: var(--white); color: var(--text-mid);
    transition: all 0.16s;
  }
  .btn:hover { background: var(--silver-light); color: var(--navy); border-color: var(--silver); }
  .btn-primary {
    background: var(--navy); border-color: var(--navy); color: white;
  }
  .btn-primary:hover { background: var(--navy-mid); border-color: var(--navy-mid); }

  /* ── ERROR ── */
  .error-msg { display: none; color: #b0220a; font-size: 0.75rem; font-weight: 700; margin-top: 8px; }
  .error-msg.visible { display: block; }

  /* ── DIVIDER ── */
  .section-divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

  /* ── END ── */
  #sec-end { display: none; }
  .result-hero { text-align: center; padding: 3rem 1rem 2rem; }
  .result-check {
    width: 72px; height: 72px; border-radius: 50%;
    background: var(--navy); color: white;
    font-size: 1.8rem; display: flex; align-items: center;
    justify-content: center; margin: 0 auto 1.5rem;
  }
  .result-title { font-size: 1.55rem; font-weight: 900; letter-spacing: -0.5px; margin-bottom: 0.5rem; color: var(--navy); }
  .result-sub { font-size: 0.9rem; color: var(--text-mid); font-weight: 500; line-height: 1.7; max-width: 400px; margin: 0 auto 1rem; }
  .esomar-note { font-size: 0.7rem; color: var(--text-light); font-weight: 500; }

  .stats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-top: 1.75rem; }
  .stat-card {
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--radius); padding: 1.1rem; text-align: center;
  }
  .stat-num { font-size: 1.9rem; font-weight: 900; color: var(--navy); }
  .stat-label { font-size: 0.68rem; font-weight: 700; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 4px; }

  .result-summary {
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--radius); overflow: hidden; margin-top: 1.5rem;
  }
  .summary-header {
    background: var(--navy); color: white;
    padding: 0.9rem 1.5rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .summary-header span:first-child { font-size: 0.82rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; }
  .summary-header span:last-child { font-size: 0.72rem; opacity: 0.65; font-weight: 500; }
  .summary-row {
    display: flex; gap: 14px; padding: 11px 1.5rem;
    border-bottom: 1px solid var(--border); font-size: 0.84rem;
  }
  .summary-row:last-child { border-bottom: none; }
  .summary-q { color: var(--navy); min-width: 36px; font-weight: 800; font-size: 0.75rem; }
  .summary-a { color: var(--text); font-weight: 500; flex: 1; }

  /* ── TERMINATED ── */
  .terminated {
    text-align: center; padding: 4rem 1rem;
  }
  .terminated-icon {
    font-size: 2.5rem; margin-bottom: 1rem;
  }
  .terminated-title { font-size: 1.3rem; font-weight: 900; color: var(--navy); margin-bottom: 0.5rem; }
  .terminated-sub { font-size: 0.88rem; color: var(--text-mid); font-weight: 500; max-width: 360px; margin: 0 auto; line-height: 1.7; }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-gradient"></div>
  <div class="hero-circle-1"></div>
  <div class="hero-circle-2"></div>
  <div class="hero-inner">
    <div class="logo-wrap">
      <!-- Shoe silhouette SVG matching KLYN logo shape -->
      <svg class="logo-shoe" viewBox="0 0 120 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="60" cy="30" rx="55" ry="24" fill="#c8cdd5" opacity="0.35"/>
        <ellipse cx="60" cy="29" rx="50" ry="21" fill="#232d56"/>
        <text x="50%" y="55%" font-family="Montserrat,sans-serif" font-weight="900" font-size="18" fill="#c8cdd5" text-anchor="middle" dominant-baseline="middle">KLYN</text>
      </svg>
      <div class="logo-text">KLYN</div>
    </div>
    <div class="hero-sub">Kit de neteja premium per a sneakers</div>
    <div class="hero-intro">
      Estem duent a terme un estudi de mercat per conèixer millor els hàbits i necessitats de les persones en relació a la neteja i el manteniment de sneakers. Les teves respostes ens ajudaran a millorar el nostre producte i adaptar-lo a les necessitats reals dels consumidors.<br><br>
      Totes les dades recollides seran tractades de forma <strong>estrictament anònima i confidencial</strong>. Aquesta enquesta compleix el codi ètic <strong>ESOMAR</strong> i el RGPD.
      <div class="esomar-tag">✦ ESOMAR · Dades anònimes · No cedides a tercers</div>
    </div>
  </div>
</div>

<!-- PROGRESS -->
<div class="progress-wrap">
  <div class="progress-meta">
    <span class="progress-label" id="progress-label">Filtres de qualificació</span>
    <span class="progress-count" id="progress-count">0 / 17</span>
  </div>
  <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- FILTRE -->
  <div class="section active" id="sec-filter">
    <span class="section-badge badge-filter">● Preguntes de filtre</span>

    <div class="q-block">
      <div class="q-meta"><span class="q-num">P1</span><span class="q-type">Dicotòmica · filtre d'exclusió</span></div>
      <div class="q-text">Tens o uses habitualment algun parell de sneakers o bambes?</div>
      <div class="options" id="p1">
        <label class="opt-label" onclick="selectOpt(this,'p1')"><input type="radio" name="p1" value="Sí, n'uso regularment"><div class="opt-dot"></div>Sí, n'uso regularment</label>
        <label class="opt-label" onclick="selectOpt(this,'p1')"><input type="radio" name="p1" value="De vegades, però no habitualment"><div class="opt-dot"></div>De vegades, però no habitualment</label>
        <label class="opt-label" onclick="selectOpt(this,'p1')"><input type="radio" name="p1" value="No, no uso sneakers"><div class="opt-dot"></div>No, no uso sneakers <span style="font-size:0.72rem;color:var(--text-light);margin-left:6px;font-weight:500;">(→ finalitza)</span></label>
      </div>
      <div class="error-msg" id="err-p1">Selecciona una opció per continuar.</div>
    </div>

    <div class="q-block">
      <div class="q-meta"><span class="q-num">P2</span><span class="q-type">Dicotòmica · filtre d'exclusió</span></div>
      <div class="q-text">Alguna vegada has netejat les teves sneakers de manera activa (no simplement passar-hi un drap)?</div>
      <div class="options" id="p2">
        <label class="opt-label" onclick="selectOpt(this,'p2')"><input type="radio" name="p2" value="Sí, ho faig o ho he fet"><div class="opt-dot"></div>Sí, ho faig o ho he fet</label>
        <label class="opt-label" onclick="selectOpt(this,'p2')"><input type="radio" name="p2" value="No ho he fet, però m'ho plantejaria"><div class="opt-dot"></div>No ho he fet, però m'ho plantejaria</label>
        <label class="opt-label" onclick="selectOpt(this,'p2')"><input type="radio" name="p2" value="No m'interessa"><div class="opt-dot"></div>No m'interessa <span style="font-size:0.72rem;color:var(--text-light);margin-left:6px;font-weight:500;">(→ finalitza)</span></label>
      </div>
      <div class="error-msg" id="err-p2">Selecciona una opció per continuar.</div>
    </div>

    <div class="nav"><span></span>
      <button class="btn btn-primary" onclick="goNext('sec-filter','sec-general',['p1','p2'],true)">Continuar →</button>
    </div>
  </div>

  <!-- GENERAL -->
  <div class="section" id="sec-general">
    <span class="section-badge badge-general">● Preguntes generals</span>

    <div class="q-block">
      <div class="q-meta"><span class="q-num">P3</span><span class="q-type">Escala multiopció</span></div>
      <div class="q-text">Amb quina freqüència neteges les teves sneakers?</div>
      <div class="options" id="p3">
        <label class="opt-label" onclick="selectOpt(this,'p3')"><input type="radio" name="p3" value="Setmanalment o més sovint"><div class="opt-dot"></div>Setmanalment o més sovint</label>
        <label class="opt-label" onclick="selectOpt(this,'p3')"><input type="radio" name="p3" value="Cada 2–4 setmanes"><div class="opt-dot"></div>Cada 2–4 setmanes</label>
        <label class="opt-label" onclick="selectOpt(this,'p3')"><input type="radio" name="p3" value="Un cop al mes o menys"><div class="opt-dot"></div>Un cop al mes o menys</label>
        <label class="opt-label" onclick="selectOpt(this,'p3')"><input type="radio" name="p3" value="Només quan estan molt brutes"><div class="opt-dot"></div>Només quan estan molt brutes</label>
        <label class="opt-label" onclick="selectOpt(this,'p3')"><input type="radio" name="p3" value="Pràcticament mai"><div class="opt-dot"></div>Pràcticament mai</label>
      </div>
      <div class="error-msg" id="err-p3">Selecciona una opció per continuar.</div>
    </div>

    <div class="q-block">
      <div class="q-meta"><span class="q-num">P4</span><span class="q-type">Multiresposta (múltiple)</span></div>
      <div class="q-text">Quins productes o mètodes uses habitualment per netejar les teves sneakers?</div>
      <div class="q-note">Pots marcar més d'una opció</div>
      <div class="options" id="p4">
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Aigua i esponja o drap"><div class="opt-dot"></div>Aigua i esponja o drap</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Sabó de roba o detergent"><div class="opt-dot"></div>Sabó de roba o detergent</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Rentadora"><div class="opt-dot"></div>Rentadora</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Raspall de roba"><div class="opt-dot"></div>Raspall de roba</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Kits especialitzats (Crep Protect, Jason Markk…)"><div class="opt-dot"></div>Kits especialitzats (Crep Protect, Jason Markk…)</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Tovalloletes de neteja"><div class="opt-dot"></div>Tovalloletes de neteja</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Netejador multiusos"><div class="opt-dot"></div>Netejador multiusos</label>
        <label class="opt-label opt-box" onclick="selectCheck(this)"><input type="checkbox" value="Cap mètode concret"><div class="opt-dot"></div>Cap mètode concret</label>
      </div>
      <div class="error-msg" id="err-p4">Selecciona almenys una opció per continuar.</div>
    </div>

    <div class="q-block">
      <div class="q-meta"><span class="q-num">P5</span><span class="q-type">Escala multiopció</span></div>
      <div class="q-text">Quantes parelles de sneakers tens aproximadament?</div>
      <div class="options" id="p5">
        <label class="opt-label" onclick="selectOpt(this,'p5')"><input type="radio" name="p5" value="1–2 parelles"><div class="opt-dot"></div>1–2 parelles</label>
        <label class="opt-label" onclick="selectOpt(this,'p5')"><input type="radio" name="p5" value="3–5 parelles"><div class="opt-dot"></div>3–5 parelles</label>
