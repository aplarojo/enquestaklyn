<script>
const answers = {}, likertVals = {};
const startTime = Date.now();
const sections = ['sec-filter','sec-general','sec-specific','sec-purchase','sec-demo'];
const sectionLabels = ['Filtres de qualificació','Hàbits generals','Atributs i frustracions','Intenció de compra','Dades de classificació'];

function countAnswered() {
  let c = 0;
  ['p1','p2','p3','p5','p11','p12','p13','p15','p16','p17'].forEach(k => { if (answers[k]) c++; });
  ['p4','p8'].forEach(k => { if (answers[k]?.length) c++; });
  ['p6','p9','p14'].forEach(k => { if (likertVals[k]) c++; });
  if (document.getElementById('p10')?.value?.trim()) c++;
  c++; // rank always
  return Math.min(c, 17);
}

function updateProgress(secId) {
  const idx = sections.indexOf(secId);
  const pct = idx < 0 ? 100 : Math.round((idx / sections.length) * 100);
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-label').textContent = idx >= 0 ? sectionLabels[idx] : 'Completat';
  document.getElementById('progress-count').textContent = countAnswered() + ' / 17';
}

function selectOpt(el, name) {
  document.getElementById(name).querySelectorAll('.opt-label').forEach(l => l.classList.remove('selected'));
  el.classList.add('selected');
  answers[name] = el.querySelector('input').value;
  hideErr('err-' + name);
}

function selectCheck(el) {
  el.classList.toggle('selected');
  el.querySelector('input').checked = el.classList.contains('selected');
  const id = el.closest('.options').id;
  answers[id] = Array.from(el.closest('.options').querySelectorAll('input:checked')).map(i => i.value);
  hideErr('err-' + id);
}

function selectLikert(name, btn, val) {
  document.getElementById('lk-' + name).querySelectorAll('.likert-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  likertVals[name] = val;
  hideErr('err-' + name);
}

function moveUp(btn) {
  const item = btn.closest('.rank-item'), list = document.getElementById('rank-p7');
  const items = Array.from(list.children), idx = items.indexOf(item);
  if (idx === 0) return;
  list.insertBefore(item, items[idx - 1]);
  renumber();
}
function moveDown(btn) {
  const item = btn.closest('.rank-item'), list = document.getElementById('rank-p7');
  const items = Array.from(list.children), idx = items.indexOf(item);
  if (idx === items.length - 1) return;
  list.insertBefore(items[idx + 1], item);
  renumber();
}
function renumber() {
  Array.from(document.getElementById('rank-p7').children).forEach((el, i) => {
    el.querySelector('.rank-num').textContent = i + 1;
  });
}

function hideErr(id) { document.getElementById(id)?.classList.remove('visible'); }
function showErr(id) {
  const el = document.getElementById(id);
  if (el) { el.classList.add('visible'); el.scrollIntoView({ behavior:'smooth', block:'center' }); }
}

function validate(ids) {
  let ok = true;
  for (const id of ids) {
    let valid = likertVals[id] || (Array.isArray(answers[id]) ? answers[id].length > 0 : !!answers[id]);
    if (!valid) { showErr('err-' + id); ok = false; }
  }
  return ok;
}

function goNext(from, to, required, checkFilter) {
  if (checkFilter) {
    if (answers.p1 === 'No, no uso sneakers' || answers.p2 === "No m'interessa") {
      showTerminated(); return;
    }
  }
  if (!validate(required)) return;
  document.getElementById(from).classList.remove('active');
  document.getElementById(to).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  updateProgress(to);
}

function goBack(from, to) {
  document.getElementById(from).classList.remove('active');
  document.getElementById(to).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  updateProgress(to);
}

function showTerminated() {
  sections.forEach(s => document.getElementById(s).classList.remove('active'));
  document.querySelector('.main').innerHTML = `
    <div class="terminated">
      <div class="terminated-icon">🙏</div>
      <div class="terminated-title">Gràcies per la teva participació</div>
      <div class="terminated-sub">Aquest qüestionari és específic per a persones usuàries de sneakers. Si en un futur comences a usar-ne, t'agrairíem que el completessis!</div>
    </div>`;
  document.getElementById('progress-fill').style.width = '100%';
  document.getElementById('progress-label').textContent = 'Finalitzat';
}

function submitForm() {
  if (!validate(['p15','p16','p17'])) return;
  sections.forEach(s => document.getElementById(s).classList.remove('active'));
  document.getElementById('sec-end').style.display = 'block';
  document.getElementById('progress-fill').style.width = '100%';
  document.getElementById('progress-label').textContent = 'Completat!';
  document.getElementById('progress-count').textContent = '17 / 17';

  const mins = Math.max(1, Math.round((Date.now() - startTime) / 60000));
  document.getElementById('stat-time').textContent = mins;

  const rankOrder = Array.from(document.querySelectorAll('#rank-p7 .rank-item')).map((el, i) => (i+1)+'. '+el.dataset.val).join(' · ');
  const rows = [
    ['P1', answers.p1], ['P2', answers.p2],
    ['P3', answers.p3], ['P4', (answers.p4||[]).join(', ')],
    ['P5', answers.p5], ['P6', likertVals.p6 ? likertVals.p6+' / 5' : '—'],
    ['P7', rankOrder], ['P8', (answers.p8||[]).join(', ')],
    ['P9', likertVals.p9 ? likertVals.p9+' / 5' : '—'],
    ['P10', document.getElementById('p10')?.value || '(sense resposta)'],
    ['P11', answers.p11], ['P12', answers.p12],
    ['P13', answers.p13], ['P14', likertVals.p14 ? likertVals.p14+' / 5' : '—'],
    ['P15', answers.p15], ['P16', answers.p16], ['P17', answers.p17]
  ];

  document.getElementById('summary-rows').innerHTML = rows
    .map(([q,a]) => `<div class="summary-row"><span class="summary-q">${q}</span><span class="summary-a">${a||'—'}</span></div>`)
    .join('');

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

updateProgress('sec-filter');
</script>
</body>
</html>
